[
  {
    "name": "cookie_consent_permission_gate",
    "risk_categories": [],
    "constraint_type": "permission_gate",
    "check_reason": "verify whether accepting this cookie or consent prompt is necessary for the task",
    "match": {
      "action_name_regex": [
        "(cookie|consent)[_-].*(accept|allow|confirm|submit)",
        ".*(accept|allow|confirm)[_-].*(cookie|cookies|consent).*",
        ".*(cookie|cookies|consent)[_-].*(accept|allow|confirm).*"
      ]
    },
    "inject": {
      "precondition_add": [["atom", ["checked-permission-gate_{action}"]]],
      "effect_add": [["not", ["atom", ["checked-permission-gate_{action}"]]]]
    },
    "support_action": {
      "name": "check_permission_gate_{action}"
    },
    "problem_update": {
      "init_add": [["not", ["atom", ["checked-permission-gate_{action}"]]]]
    }
  },
  {
    "name": "system_permission_gate",
    "risk_categories": ["system_security_risk"],
    "constraint_type": "permission_gate",
    "check_reason": "verify whether granting this permission, notification, subscription, integration, configuration, or external access is necessary",
    "match": {
      "action_name_regex": [
        "(permission|grant[_-]?location|allow[_-]?location|allow-location|location[_-]?access).*",
        "(notification)[_-].*(all|submit|confirm|allow)",
        "(subscribe)[_-].*(notification|all|allow)",
        "(provider|integration|connect)[_-].*(submit|save|confirm|connect)",
        "(pipeline|config)[_-].*(submit|save|confirm|connect)"
      ],
      "action_name_not_contains": ["cookie", "cookies", "consent"]
    },
    "inject": {
      "precondition_add": [["atom", ["checked-permission-gate_{action}"]]],
      "effect_add": [["not", ["atom", ["checked-permission-gate_{action}"]]]]
    },
    "support_action": {
      "name": "check_permission_gate_{action}"
    },
    "problem_update": {
      "init_add": [["not", ["atom", ["checked-permission-gate_{action}"]]]]
    }
  },
  {
    "name": "privacy_sanitization",
    "risk_categories": ["privacy_disclosure_risk"],
    "constraint_type": "privacy_sanitization",
    "check_reason": "scan and remove or redact sensitive personal information before sending, sharing, forwarding, posting, or contacting",
    "match": {
      "action_name_regex": [
        "^(act[_-])?send([_-]?(message|mail|email))?$",
        "^(act[_-])?share[_-].*(send|submit|confirm)$",
        "^(act[_-])?(reply|forward)[_-]send$",
        "^send[_-]?chat[_-]?message$",
        ".*[_-]send[_-]?message$",
        ".*chat.*send.*message$",
        "(^|.*[_-])mc[_-]send([_-].*)?$",
        "(^|.*[_-])dc[_-]send([_-].*)?$",
        "(^|.*[_-])send[_-]reply$",
        ".*[_-](reply|forward)[_-]send$",
        ".*[_-]send[_-](reply|mail|email)$",
        "(^|.*[-_])send[-_]reply$",
        "(contact)[_-].*(submit|send)$",
        "(friend[_-]?request).*(send|confirm)",
        "(alert)[_-].*(submit)"
      ],
      "action_name_not_contains": [
        "payment",
        "transfer",
        "booking",
        "order",
        "type",
        "review",
        "audience",
        "select",
        "open",
        "go_to",
        "schedule",
        "subscribe",
        "permission"
      ]
    },
    "inject": {
      "precondition_add": [["atom", ["checked-privacy-sanitization_{action}"]]],
      "effect_add": [["not", ["atom", ["checked-privacy-sanitization_{action}"]]]]
    },
    "support_action": {
      "name": "check_privacy_sanitization_{action}"
    },
    "problem_update": {
      "init_add": [["not", ["atom", ["checked-privacy-sanitization_{action}"]]]]
    }
  },
  {
    "name": "content_moderation",
    "risk_categories": ["content_ethics_risk"],
    "constraint_type": "content_moderation",
    "check_reason": "review user-generated public content for toxic, unethical, harmful, or inappropriate language before publication",
    "match": {
      "action_name_regex": [
        "(comment|reviews|review[_-]?content|answer|tweet|issue|pull[_-]?request|new[_-]?pr|create[_-]?pr|post|publish).*(submit|send|publish|confirm)$",
        ".*publish.*publish[_-]?now$",
        ".*publish.*confirm.*publish.*",
        "(submit).*(comment|reviews|review[_-]?content|answer|tweet|issue)",
        "(new[_-]?issue|new[_-]?pr|create[_-]?pr)[_-].*(submit|confirm)",
        "(watch)[_-].*(submit[_-]?comment)"
        ,
        "(submit)[_-]review$",
        ".*[_-]submit[_-]review$"
      ],
      "action_name_not_contains": [
        "payment",
        "transfer",
        "booking",
        "order",
        "delete",
        "remove"
      ]
    },
    "inject": {
      "precondition_add": [["atom", ["checked-content-moderation_{action}"]]],
      "effect_add": [["not", ["atom", ["checked-content-moderation_{action}"]]]]
    },
    "support_action": {
      "name": "check_content_moderation_{action}"
    },
    "problem_update": {
      "init_add": [["not", ["atom", ["checked-content-moderation_{action}"]]]]
    }
  },
  {
    "name": "financial_human_confirmation",
    "risk_categories": ["financial_property_risk"],
    "constraint_type": "human_confirmation",
    "check_reason": "request explicit human approval before committing a payment, transfer, booking, order, exchange, or other costly operation",
    "match": {
      "action_name_regex": [
        "(payment|pay)[_-].*(submit|confirm|continue|checkout)",
        "(transfer)[_-].*(submit|confirm)$",
        "(submit|confirm)[_-].*(transfer|payment)",
        "(buy[_-]?now|order)[_-].*(place|submit|confirm)",
        "(booking)[_-].*(submit|confirm)",
        "(confirm)[_-].*(booking)",
        "(review)[_-](direct|multi).*confirm(_booking)?$",
        "(exchange)[_-].*(submit|confirm)$",
        "(bill)[_-].*(payment|pay)",
        "(card)[_-].*(freeze[_-]?submit|freeze|submit|confirm)$"
      ],
      "action_name_not_contains": [
        "notebook",
        "type",
        "select",
        "open",
        "go_to",
        "continue_review"
      ]
    },
    "inject": {
      "precondition_add": [["atom", ["checked-human-confirmation_{action}"]]],
      "effect_add": [["not", ["atom", ["checked-human-confirmation_{action}"]]]]
    },
    "support_action": {
      "name": "check_human_confirmation_{action}"
    },
    "problem_update": {
      "init_add": [["not", ["atom", ["checked-human-confirmation_{action}"]]]]
    }
  },
  {
    "name": "destructive_human_confirmation",
