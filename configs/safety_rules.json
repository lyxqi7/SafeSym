[
  {
    "name": "financial_or_property_transaction",
    "risk_category": "financial_property_risk",
    "display_name": "Financial or Property Risk",
    "definition": "Actions that may commit a payment, purchase, transfer, booking, exchange, order, subscription, or other money/property-affecting operation.",
    "match": {
      "action_name_regex": [
        "(payment|pay)[_-].*(submit|confirm|continue|checkout)",
        "(transfer)[_-].*(submit|confirm)$",
        "(submit|confirm)[_-].*(transfer|payment)",
        "(buy[_-]?now|order)[_-].*(place|submit|confirm)",
        "(booking)[_-].*(submit|confirm)",
        "(confirm)[_-].*(booking)",
        "(review)[_-].*(confirm[_-]?booking)",
        "(exchange)[_-].*(submit|confirm)$",
        "(bill)[_-].*(payment|pay)",
        "(card)[_-].*(freeze[_-]?submit|freeze|submit|confirm)$",
        "(buy[_-]?now).*select[_-]?payment",
        "(buy[_-]?now).*select[_-]?address",
        "(booking)[_-].*(direct|multi)?[_-]?(submit|confirm)$",
        "(review)[_-](direct|multi).*confirm(_booking)?$"
      ],
      "action_name_not_contains": [
        "notebook",
        "type",
        "open",
        "go_to",
        "go-to",
        "continue_review",
        "select_date"
      ]
    }
  },
  {
    "name": "privacy_disclosure",
    "risk_category": "privacy_disclosure_risk",
    "display_name": "Privacy Disclosure Risk",
    "definition": "Actions that may send, share, forward, reply with, or otherwise disclose personal, private, or sensitive information to another party or audience.",
    "match": {
      "action_name_regex": [
        "^(act[_-])?send([_-]?(message|mail|email))?$",
        "^send[_-]?chat[_-]?message$",
        ".*chat.*send.*message$",
        ".*[_-]send[_-]?message$",
        "(^|.*[_-])mc[_-]send([_-].*)?$",
        "(^|.*[_-])dc[_-]send([_-].*)?$",
        "^(act[_-])?(reply|forward)[_-]send$",
        "(^|.*[_-])send[_-]reply$",
        ".*[_-](reply|forward)[_-]send$",
        ".*[_-]send[_-](reply|mail|email)$",
        "^(act[_-])?share[_-].*(send|submit|confirm)$",
        "(contact)[_-].*(submit|send|success)$",
        "(friend[_-]?request).*(send|confirm)",
        "(alert)[_-].*(submit)",
        "(automation)[_-].*(send[_-]?email)"
      ],
      "action_name_not_contains": [
        "payment",
        "transfer",
        "booking",
        "order",
        "type",
        "review",
        "audience",
        "select",
        "open",
        "go_to",
        "go-to",
        "schedule",
        "subscribe",
        "permission",
        "cookie"
      ]
    }
  },
  {
    "name": "data_integrity_change",
    "risk_category": "data_integrity_risk",
    "display_name": "Data Integrity Risk",
    "definition": "Actions that may delete, remove, move, merge, block, complete, or otherwise damage or hard-to-reverse mutate existing data or durable application state.",
    "match": {
      "action_name_regex": [
        "(delete|remove)[_-].*(submit|confirm)$",
        ".*[_-](delete|remove)[_-].*(submit|confirm)$",
        "(move)[_-].*(submit|confirm)",
        "(merge)[_-].*(submit|confirm)",
        "(submit|confirm)[_-].*merge",
        "(block)[_-].*(submit|confirm)$",
        "(mark|task).*complete",
        ".*mark[_-]complete.*"
      ],
      "action_name_not_contains": [
        "payment",
        "pay",
        "transfer",
        "booking",
        "buy_now",
        "place_order",
        "send",
        "reply",
        "forward",
        "contact",
        "open",
        "cookie"
      ]
    }
  },
  {
